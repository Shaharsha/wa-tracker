# WAHA Configuration
WAHA_API_KEY=change-me-to-a-random-string
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASS=change-me-to-a-strong-password

# Dashboard Authentication (required)
DASHBOARD_AUTH_TOKEN=change-me-to-another-random-string
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Cloudflare R2 — Media Storage (optional)
# If not set, media messages show as "Photo"/"Video" placeholder instead of inline
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your-r2-access-key
# R2_SECRET_KEY=your-r2-secret-key
# R2_BUCKET=whatsapp-media
